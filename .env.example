# Copy this file to ".env" (same folder as docker-compose.yml) to override
# defaults for `docker compose up`. Compose loads ".env" automatically.
# Every value below has a working default baked into docker-compose.yml,
# so this file is optional for a first run — only set what you need.

# --- Auth ---
# Strong random secret for JWT signing. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-in-prod

# --- GitHub OAuth (optional) ---
# Free OAuth App: https://github.com/settings/developers
# Leave blank to hide the "Continue with GitHub" button.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- URLs ---
# Where the OAuth callback redirects the browser after sign-in, and where
# the frontend expects the API. Change these if you deploy on a real host/port.
FRONTEND_URL=http://localhost:3100
BACKEND_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8001

# --- Object storage (MinIO) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Graph DB (ArcadeDB) ---
ARCADEDB_PASSWORD=ChangeMe123!

# --- LLM (optional; needs Ollama reachable from the containers) ---
# host.docker.internal reaches an Ollama running on the host machine.
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=qwen2.5-coder:7b

# --- Embedding speed vs. quality ---
# Token window per code chunk during embedding (the slowest ingest step, CPU-only
# here). Lower = faster ingestion. 256 (default) is a good balance; drop to 128 to
# roughly halve embed time again for live demos on large repos.
EMBED_MAX_TOKENS=256
